{
  "manifest_version": 3,
  "name": "Tab Bridge",
  "version": "0.1.0",
  "description": "Transfer tabs between browser profiles",
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-bridge@relexx.de",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "nativeMessaging",
    "menus",
    "tabs",
    "activeTab",
    "notifications"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-48.png"
  }
}
